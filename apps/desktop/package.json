    "test": "vitest"
  },
  "dependencies": {
    "@tamagui/config": "2.0.0-rc.16",
    "@tamagui/next-theme": "2.0.0-rc.16",
    "app": "0.0.0",
    "next": "16.1.1",
    "raf": "^3.4.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-web": "0.21.2",
    "tamagui": "2.0.0-rc.16",
    "vercel": "latest"
  },
  "devDependencies": {
    "@tamagui/next-plugin": "2.0.0-rc.16",
    "@tauri-apps/cli": "^2.5.0",
    "@types/node": "^20.14.1",
    "eslint-config-next": "^16.1.1",
    "tree-kill": "^1.2.2",
    "vitest": "^2.1.1"
  }
