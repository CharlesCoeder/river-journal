{
  "name": "desktop-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "cd ../.. && yarn build && cd apps/desktop && tamagui build --target web ../../packages/app -- next build",
    "prebuild": "cd ../.. && yarn build && cd apps/desktop && tamagui build --target web ../../packages/app -- next build",
    "start": "next start",
    "serve": "NODE_ENV=production next start --port 8151",
