+        // PATCH: rename any leftover RN `testID` to `data-testid`. The static-value
+        // path is renamed at build-time via getSplitStyles, but dynamic
+        // (non-evaluable) values fail attemptEvalSafe and pass through with the
+        // React Native prop name, which is invalid on a flattened DOM element.
+        for (const _a of finalAttrs) {
+          if (t.isJSXAttribute(_a) && t.isJSXIdentifier(_a.name) && _a.name.name === "testID") {
+            _a.name.name = "data-testid";
+          }
+        }
+        // PATCH: drop duplicate-named attributes before writing them back. When the
+        // optimizing compiler flattens an element that has a testID (or other RN
+        // prop mapped to a DOM attr), it can emit the same attribute twice
+        // (e.g. `data-testid="x" data-testid="x"`), which is invalid JSX and fails
+        // strict type-checking. Duplicate attribute names are never valid, so
+        // de-duplicating here (keeping the first occurrence) is always safe.
+        {
+          const _seenAttrNames = new Set();
+          for (let _i = 0; _i < finalAttrs.length; _i++) {
+            const _a = finalAttrs[_i];
+            if (t.isJSXAttribute(_a) && t.isJSXIdentifier(_a.name)) {
+              if (_seenAttrNames.has(_a.name.name)) {
+                finalAttrs.splice(_i, 1);
+                _i--;
+              } else {
+                _seenAttrNames.add(_a.name.name);
+              }
+            }
+          }
+        }
         node.attributes = finalAttrs;
       }
     });
